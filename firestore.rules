rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function bootstrapAdmin() {
      return signedIn()
        && (
          request.auth.token.email == 'thiago.bekrman@educacao.mg.gov.br'
          || request.auth.token.email == 'thiago@educacaoensa.com'
        );
    }

    function profile() {
      return get(/databases/$(database)/documents/usuarios/$(request.auth.uid));
    }

    function hasUidProfile() {
      return signedIn() && exists(/databases/$(database)/documents/usuarios/$(request.auth.uid));
    }

    function hasEmailProfile() {
      return signedIn() && exists(/databases/$(database)/documents/usuarios/$(request.auth.token.email));
    }

    function activeUser() {
      return signedIn()
        && (
          bootstrapAdmin()
          ||
          (hasUidProfile() && profile().data.status == 'active')
          || (hasEmailProfile() && emailProfile().data.status == 'active')
        );
    }

    function authorizedEmail() {
      return signedIn()
        && hasEmailProfile()
        && emailProfile().data.status == 'active';
    }

    function emailProfile() {
      return get(/databases/$(database)/documents/usuarios/$(request.auth.token.email));
    }

    function admin() {
      return bootstrapAdmin()
        || (
          activeUser()
          && (
            (hasUidProfile() && profile().data.role == 'admin')
            || (hasEmailProfile() && emailProfile().data.role == 'admin')
          )
        );
    }

    match /alunos/{docId} {
      allow read, create, update, delete: if activeUser();
    }

    match /historicos/{docId} {
      allow read, create, update, delete: if activeUser();
    }

    match /notas/{docId} {
      allow read, create, update, delete: if activeUser();
    }

    match /certificados/{docId} {
      allow read, create, update, delete: if activeUser();
    }

    match /config/{docId} {
      allow read, create, update, delete: if activeUser();
    }

    match /usuarios/{docId} {
      allow read: if signedIn();
      allow create: if admin()
        || (signedIn()
          && docId == request.auth.uid
          && authorizedEmail()
          && request.resource.data.role == emailProfile().data.role
          && request.resource.data.status == 'active');
      allow update: if admin()
        || (signedIn()
          && docId == request.auth.uid
          && activeUser()
          && request.resource.data.role == resource.data.role
          && request.resource.data.status == resource.data.status);
      allow delete: if admin();
    }
  }
}
